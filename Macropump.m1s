Dim x, y, z As Double
Dim filePath As String

filePath = "C:\Mach3\macros\THC300M3\coords.txt"

x = GetOEMDRO(800) ' X Position
y = GetOEMDRO(801) ' Y Position
z = GetOEMDRO(802) ' Z Position

Open filePath For Output As #1
Print #1, x & "," & y & "," & z
Close #1

Message "System File Sync Active: X= " & Format(x, "0.000") & " Y= " & Format(y, "0.000") & " Z= " & Format(z, "0.000")
